{
  "name": "herd-xdebug-toggler",
  "publisher": "patrick-levesque",
  "displayName": "Herd Xdebug Toggler",
  "description": "Enable or disable Xdebug extention for Laravel Herd",
  "icon": "images/herd-xdebug-toggler.png",
  "version": "1.3.1",
  "author": "Patrick Levesque",
  "license": "MIT",
  "galleryBanner": {
    "color": "#100f11",
    "theme": "dark"
  },
  "repository": "github:patrick-levesque/herd-xdebug-toggler",
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "debug",
    "herd",
    "laravel",
    "php",
    "xdebug"
  ],
  "engines": {
    "vscode": "^1.104.0"
  },
  "activationEvents": [
    "onLanguage:php",
    "workspaceContains:**/artisan"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "herd-xdebug-toggler.enableXdebug",
        "title": "Enable Xdebug"
      },
      {
        "command": "herd-xdebug-toggler.disableXdebug",
        "title": "Disable Xdebug"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Herd Xdebug Toggler",
      "properties": {
        "herdXdebugToggler.automaticDetection": {
          "order": 1,
          "type": "boolean",
          "description": "Automatically toggle Xdebug when breakpoints change or debug sessions start or stop.",
          "default": true
        },
        "herdXdebugToggler.detectionMode": {
          "order": 2,
          "markdownDescription": "Choose how Xdebug should be toggled. This setting only applies when [Automatic Detection](#herdXdebugToggler.automaticDetection) is enabled.",
          "type": "string",
          "enum": ["breakpointChange", "debugSession"],
          "enumDescriptions": [
            "Toggle Xdebug on breakpoint changes.",
            "Toggle Xdebug on debug session start/stop."
          ],
          "default": "debugSession"
        },
        "herdXdebugToggler.showNotifications": {
          "order": 3,
          "type": "boolean",
          "description": "Show notifications when Xdebug is enabled or disabled.",
          "default": true
        },
        "herdXdebugToggler.herdPro": {
          "order": 4,
          "type": "boolean",
          "markdownDescription": "Enable integration with Herd Pro [Xdebug Detection](https://herd.laravel.com/docs/macos/debugging/xdebug-detection) (**macOS only**).",
          "default": false
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.104.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "eslint": "^9.36.0",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
